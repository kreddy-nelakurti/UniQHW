	)
	(text_box "IMU (U11 - LSM6DSVTR) - a six-axis Inertial Measurement Unit containing a 3-axis accelerometer and 3-axis gyroscope. It provides motion, orientation and gesture data to the MCU over the I²C bus (SCL/SDA). C34 and C35 (100nF) are local decoupling capacitors required for stable operation. The MCU can use the IMU for motion detection, screen orientation, activity recognition or future gesture-based user interfaces."
		(exclude_from_sim no)
		(at -43.18 144.78 0)
		(size 76.2 13.97)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0.635)
			(type solid)
		)
		(fill
			(type color)
			(color 0 255 0 0.2)
		)
		(effects
			(font
				(face "Arial")
				(size 1.27 1.27)
				(thickness 1)
				(bold yes)
			)
			(justify left top)
		)
		(uuid "7e764a64-f8bc-4846-ac8c-406ca1f5b5ef")
	)
	(text_box "Backlight Driver\n"
		(exclude_from_sim no)
		(at 308.61 92.71 0)
		(size 69.85 80.01)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
